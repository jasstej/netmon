        SETTINGS['alert_threshold_mb_s'] = float(settings['alert_threshold_mb_s'])
    if 'check_unknown_process' in settings:
        SETTINGS['check_unknown_process'] = bool(settings['check_unknown_process'])
    if 'alert_unknown_process_threshold_mb_s' in settings:
