# Helper: format byte counts
def format_bytes(b):
    if b >= 1024 * 1024 * 1024:
        return f"{b / (1024 * 1024 * 1024):.2f} GB"
    elif b >= 1024 * 1024:
        return f"{b / (1024 * 1024):.2f} MB"
    elif b >= 1024:
        return f"{b / 1024:.2f} KB"
    else:
        return f"{b} B"

def format_speed(b_s):
    return f"{format_bytes(b_s)}/s"

# Helper: parse UID to Username
def get_username(uid):
    if uid in uid_to_username:
        return uid_to_username[uid]
    try:
        username = pwd.getpwuid(uid).pw_name
    except Exception:
        username = str(uid)
    uid_to_username[uid] = username
    return username

# Helper: parse Linux connection addresses in hex
def parse_ipv4_hex(hex_str):
    ip_bytes = bytes.fromhex(hex_str)
    return socket.inet_ntoa(ip_bytes[::-1])

def parse_ipv6_hex(hex_str):
    ip_bytes = bytes.fromhex(hex_str)
    reversed_blocks = []
    for i in range(0, 32, 8):
        block = ip_bytes[i:i+4]
        reversed_blocks.append(block[::-1])
    return socket.inet_ntop(socket.AF_INET6, b''.join(reversed_blocks))

def parse_hex_addr(hex_addr, is_ipv6):
    parts = hex_addr.split(':')
    if len(parts) != 2:
        raise ValueError("Invalid address hex format")
    ip_hex, port_hex = parts
    port = int(port_hex, 16)
    if is_ipv6:
        ip = parse_ipv6_hex(ip_hex)
    else:
        ip = parse_ipv4_hex(ip_hex)
    return ip, port

def parse_proc_net_line(line, is_ipv6=False):
    parts = line.strip().split()
    if len(parts) < 10:
        return None
    try:
        local_ip, local_port = parse_hex_addr(parts[1], is_ipv6)
        remote_ip, remote_port = parse_hex_addr(parts[2], is_ipv6)
        inode = int(parts[9])
        uid = int(parts[7])
        state = parts[3]
        return {
            'local_ip': local_ip,
            'local_port': local_port,
            'remote_ip': remote_ip,
            'remote_port': remote_port,
            'inode': inode,
            'uid': uid,
            'state': state
        }
    except Exception:
        return None

# Helper: Docker Container resolver via Unix Socket HTTP API
def resolve_docker_container_name(container_id):
    if not container_id:
        return None
    if container_id in container_name_cache:
        return container_name_cache[container_id]
        
    # Standard Unix socket request
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(0.1)
        s.connect("/var/run/docker.sock")
        request = f"GET /containers/{container_id}/json HTTP/1.0\r\n\r\n"
        s.sendall(request.encode())
        response = b""
        while True:
            chunk = s.recv(4096)
            if not chunk:
                break
            response += chunk
        s.close()
        parts = response.split(b"\r\n\r\n", 1)
        if len(parts) == 2:
            header, body = parts
            if b"200 OK" in header:
                info = json.loads(body.decode())
                name = info.get("Name", "").lstrip("/")
                container_name_cache[container_id] = name
                return name
    except Exception:
        pass
        
    short_id = container_id[:12]
    container_name_cache[container_id] = short_id
    return short_id

# Helper: parse PID cgroup container ID
def extract_container_id(cgroup_content):
    match = re.search(r'/docker/([0-9a-fA-F]{64})', cgroup_content)
    if match:
        return match.group(1)
    match = re.search(r'/libpod-([0-9a-fA-F]{64})', cgroup_content)
    if match:
        return match.group(1)
    match = re.search(r'docker-([0-9a-fA-F]{64})\.scope', cgroup_content)
    if match:
        return match.group(1)
    return None

# Database Management
class DBManager:
    def __init__(self, db_path):
        self.db_path = db_path
        self.init_db()
        
    def init_db(self):
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Raw table: holds 1-minute aggregates, pruned after 24 hours
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS traffic_raw (
                timestamp INTEGER,
                name TEXT,
                user TEXT,
                container TEXT,
                bytes_sent INTEGER,
                bytes_recv INTEGER
            )
        ''')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_raw_time ON traffic_raw(timestamp)')
        
        # Hourly table with unique constraints, pruned after 30 days
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS traffic_hourly (
                timestamp INTEGER,
                name TEXT,
                user TEXT,
                container TEXT,
                bytes_sent INTEGER,
                bytes_recv INTEGER
            )
        ''')
        cursor.execute('CREATE UNIQUE INDEX IF NOT EXISTS idx_hourly_unique ON traffic_hourly(timestamp, name, user, container)')
        
        # Daily table with unique constraints, pruned after 365 days
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS traffic_daily (
                timestamp INTEGER,
                name TEXT,
                user TEXT,
                container TEXT,
                bytes_sent INTEGER,
                bytes_recv INTEGER
            )
        ''')
        cursor.execute('CREATE UNIQUE INDEX IF NOT EXISTS idx_daily_unique ON traffic_daily(timestamp, name, user, container)')
        
        # Monthly table with unique constraints, kept forever
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS traffic_monthly (
                timestamp INTEGER,
                name TEXT,
                user TEXT,
                container TEXT,
                bytes_sent INTEGER,
                bytes_recv INTEGER
            )
        ''')
        cursor.execute('CREATE UNIQUE INDEX IF NOT EXISTS idx_monthly_unique ON traffic_monthly(timestamp, name, user, container)')
        
        # Alerts table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS alerts (
                timestamp INTEGER,
                process_name TEXT,
                message TEXT,
                severity TEXT
            )
        ''')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_alerts_time ON alerts(timestamp)')
        
        conn.commit()
        conn.close()

    def write_raw_batch(self, batch):
        if not batch:
            return
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.executemany('''
            INSERT INTO traffic_raw (timestamp, name, user, container, bytes_sent, bytes_recv)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', batch)
        conn.commit()
        conn.close()
        
    def rollup_and_prune(self):
        now = int(time.time())
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        try:
            # 1. Rollup raw to hourly (older than 1 hour)
            one_hour_ago = now - 3600
            cursor.execute('''
                INSERT OR REPLACE INTO traffic_hourly (timestamp, name, user, container, bytes_sent, bytes_recv)
                SELECT (timestamp / 3600) * 3600, name, user, container, SUM(bytes_sent), SUM(bytes_recv)
                FROM traffic_raw
                WHERE timestamp <= ?
                GROUP BY (timestamp / 3600) * 3600, name, user, container
            ''', (one_hour_ago,))
            
            # Prune raw older than 24 hours
            twenty_four_hours_ago = now - 86400
            cursor.execute('DELETE FROM traffic_raw WHERE timestamp <= ?', (twenty_four_hours_ago,))
            
            # 2. Rollup hourly to daily (older than 1 day)
            one_day_ago = now - 86400
            cursor.execute('''
                INSERT OR REPLACE INTO traffic_daily (timestamp, name, user, container, bytes_sent, bytes_recv)
                SELECT (timestamp / 86400) * 86400, name, user, container, SUM(bytes_sent), SUM(bytes_recv)
                FROM traffic_hourly
                WHERE timestamp <= ?
                GROUP BY (timestamp / 86400) * 86400, name, user, container
            ''', (one_day_ago,))
            
            # Prune hourly older than 30 days
            thirty_days_ago = now - 2592000
            cursor.execute('DELETE FROM traffic_hourly WHERE timestamp <= ?', (thirty_days_ago,))
            
            # 3. Rollup daily to monthly (older than 30 days)
            cursor.execute('''
                INSERT OR REPLACE INTO traffic_monthly (timestamp, name, user, container, bytes_sent, bytes_recv)
                SELECT 
                    cast(strftime('%s', strftime('%Y-%m-01 00:00:00', datetime(timestamp, 'unixepoch'))) as integer),
                    name, user, container, SUM(bytes_sent), SUM(bytes_recv)
                FROM traffic_daily
                WHERE timestamp <= ?
                GROUP BY 
                    strftime('%Y-%m', datetime(timestamp, 'unixepoch')),
                    name, user, container
            ''', (thirty_days_ago,))
            
            # Prune daily older than 365 days
            three_hundred_sixty_five_days_ago = now - 31536000
            cursor.execute('DELETE FROM traffic_daily WHERE timestamp <= ?', (three_hundred_sixty_five_days_ago,))
            
            conn.commit()
            logger.info("Database rollup and pruning run completed successfully.")
        except Exception as e:
            conn.rollback()
            logger.error(f"Database rollup transactional failure: {e}")
        finally:
            conn.close()

    def get_history(self, range_str):
        now = int(time.time())
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        cursor = conn.cursor()
        
        if range_str == '24h':
            cutoff = now - 86400
            cursor.execute('''
                SELECT timestamp, name, user, container, bytes_sent, bytes_recv
                FROM traffic_raw
                WHERE timestamp >= ?
                ORDER BY timestamp ASC
            ''', (cutoff,))
        elif range_str == '7d':
            cutoff = now - 7 * 86400
            cursor.execute('''
                SELECT timestamp, name, user, container, bytes_sent, bytes_recv
                FROM traffic_hourly
                WHERE timestamp >= ?
                ORDER BY timestamp ASC
            ''', (cutoff,))
        elif range_str == '30d':
            cutoff = now - 30 * 86400
            cursor.execute('''
                SELECT timestamp, name, user, container, bytes_sent, bytes_recv
                FROM traffic_daily
                WHERE timestamp >= ?
                ORDER BY timestamp ASC
            ''', (cutoff,))
        else:
            cursor.execute('''
                SELECT timestamp, name, user, container, bytes_sent, bytes_recv
                FROM traffic_monthly
                ORDER BY timestamp ASC
            ''')
            
        rows = cursor.fetchall()
        result = [dict(row) for row in rows]
        conn.close()
        return result

    def get_top_consumers(self, range_str, limit=20):
        now = int(time.time())
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        cursor = conn.cursor()
        
        table = "traffic_monthly"
        cutoff = 0
        if range_str == '24h':
            table = "traffic_raw"
            cutoff = now - 86400
        elif range_str == '7d':
            table = "traffic_hourly"
            cutoff = now - 7 * 86400
        elif range_str == '30d':
            table = "traffic_daily"
            cutoff = now - 30 * 86400
            
        query = f'''
            SELECT name, user, container, SUM(bytes_sent) as sent, SUM(bytes_recv) as recv, SUM(bytes_sent + bytes_recv) as total
            FROM {table}
            WHERE timestamp >= ?
            GROUP BY name, user, container
            ORDER BY total DESC
            LIMIT ?
        '''
        cursor.execute(query, (cutoff, limit))
        rows = cursor.fetchall()
        result = [dict(row) for row in rows]
        conn.close()
        return result

    def get_alerts(self, limit=50):
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        cursor = conn.cursor()
        cursor.execute('SELECT timestamp, process_name, message, severity FROM alerts ORDER BY timestamp DESC LIMIT ?', (limit,))
        rows = cursor.fetchall()
        result = [dict(row) for row in rows]
        conn.close()
        return result

