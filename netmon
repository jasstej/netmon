# Scan /proc for sockets and map PIDs
def scan_proc_fds():
    global inode_to_proc
    new_inode_to_proc = {}
    
    try:
        pids = [d for d in os.listdir('/proc') if d.isdigit()]
    except Exception as e:
        logger.error(f"Cannot read /proc: {e}")
        return
        
    current_pids_set = set(int(p) for p in pids)
    # Evict dead PIDs from cache
    for cached_pid in list(pid_cache.keys()):
        if cached_pid not in current_pids_set:
            pid_cache.pop(cached_pid, None)
            
    for pid_str in pids:
        pid = int(pid_str)
        proc_name = "unknown"
        uid = 0
        container_name = None
        
        if pid in pid_cache:
            proc_name, user, container_name = pid_cache[pid]
        else:
            try:
                with open(f'/proc/{pid_str}/comm', 'r') as f:
                    proc_name = f.read().strip()
                if not proc_name:
                    with open(f'/proc/{pid_str}/cmdline', 'r') as f:
                        cmd = f.read().strip().split('\x00')[0]
                        if cmd:
                            proc_name = os.path.basename(cmd)
            except Exception:
                pass
                
            try:
                with open(f'/proc/{pid_str}/status', 'r') as f:
                    for line in f:
                        if line.startswith('Uid:'):
                            uid = int(line.split()[1])
                            break
            except Exception:
                pass
                
            user = get_username(uid)
            
            # Resolve cgroups for Docker containers
            try:
                with open(f'/proc/{pid_str}/cgroup', 'r') as f:
                    container_id = extract_container_id(f.read())
                    if container_id:
                        container_name = resolve_docker_container_name(container_id)
            except Exception:
                pass
                
            pid_cache[pid] = (proc_name, user, container_name)
            
        # Scan file descriptors for open sockets
        fd_dir = f'/proc/{pid_str}/fd'
        try:
            fds = os.listdir(fd_dir)
        except Exception:
            continue
            
        for fd in fds:
            try:
                link = os.readlink(f'{fd_dir}/{fd}')
                if link.startswith('socket:['):
                    inode = int(link[8:-1])
                    new_inode_to_proc[inode] = {
                        'pid': pid,
                        'name': proc_name,
                        'user': user,
                        'container': container_name
                    }
            except Exception:
                continue
                
    inode_to_proc = new_inode_to_proc

last_socket_scan_time = 0.0

# Parse socket list from /proc/net/
def scan_active_sockets():
    global active_sockets, last_socket_scan_time
    now = time.time()
    # Rate limit to at most 10 times per second
    if now - last_socket_scan_time < 0.1:
        return
    last_socket_scan_time = now
    
    new_active_sockets = {}
    new_inodes = False
    
    files = [
        ('/proc/net/tcp', False, 'tcp'),
        ('/proc/net/tcp6', True, 'tcp'),
        ('/proc/net/udp', False, 'udp'),
        ('/proc/net/udp6', True, 'udp')
    ]
    
    for path, is_ipv6, proto in files:
        if not os.path.exists(path):
            continue
        try:
            with open(path, 'r') as f:
                next(f) # skip header
                for line in f:
                    parsed = parse_proc_net_line(line, is_ipv6)
                    if parsed:
                        key = (parsed['local_ip'], parsed['local_port'], 
                               parsed['remote_ip'], parsed['remote_port'], proto)
                        inode = parsed['inode']
                        uid = parsed['uid']
                        new_active_sockets[key] = (inode, uid)
                        if inode not in inode_to_proc:
                            new_inodes = True
        except Exception as e:
            logger.error(f"Error scanning {path}: {e}")
            
    active_sockets = new_active_sockets
    if new_inodes:
        proc_scan_event.set()

# Active sockets match lookup
def lookup_socket(src_ip, src_port, dst_ip, dst_port, proto, version):
    wildcard_ip = '0.0.0.0' if version == 4 else '::'
    
    # Outbound checks
    keys_out = [
        (src_ip, src_port, dst_ip, dst_port, proto),
        (src_ip, src_port, wildcard_ip, 0, proto),
        (wildcard_ip, src_port, dst_ip, dst_port, proto),
        (wildcard_ip, src_port, wildcard_ip, 0, proto)
    ]
    for k in keys_out:
        if k in active_sockets:
            inode, uid = active_sockets[k]
            return inode, uid, 'out'
            
    # Inbound checks
    keys_in = [
        (dst_ip, dst_port, src_ip, src_port, proto),
        (dst_ip, dst_port, wildcard_ip, 0, proto),
        (wildcard_ip, dst_port, src_ip, src_port, proto),
        (wildcard_ip, dst_port, wildcard_ip, 0, proto)
    ]
    for k in keys_in:
        if k in active_sockets:
            inode, uid = active_sockets[k]
            return inode, uid, 'in'
            
    return None, None, None

# Sniffer parser
def parse_packet(data):
    if len(data) < 20:
        return None
        
    version = data[0] >> 4
    if version == 4:
        iph = struct.unpack('!BBHHHBBH4s4s', data[:20])
        ihl = (iph[0] & 0x0F) * 4
        if len(data) < ihl:
            return None
        proto = iph[6]
        src_ip = socket.inet_ntoa(iph[8])
        dst_ip = socket.inet_ntoa(iph[9])
        payload = data[ihl:]
    elif version == 6:
        if len(data) < 40:
            return None
        iph = struct.unpack('!LHBB16s16s', data[:40])
        proto = iph[2]
        src_ip = socket.inet_ntop(socket.AF_INET6, iph[4])
        dst_ip = socket.inet_ntop(socket.AF_INET6, iph[5])
        payload = data[40:]
    else:
        return None
        
    src_port = None
    dst_port = None
    proto_name = None
    
    if proto == 6: # TCP
        proto_name = 'tcp'
        if len(payload) >= 4:
            src_port, dst_port = struct.unpack('!HH', payload[:4])
    elif proto == 17: # UDP
        proto_name = 'udp'
        if len(payload) >= 4:
            src_port, dst_port = struct.unpack('!HH', payload[:4])
            
    if src_port is not None and dst_port is not None:
        return {
            'src_ip': src_ip,
            'src_port': src_port,
            'dst_ip': dst_ip,
            'dst_port': dst_port,
            'proto': proto_name,
            'len': len(data),
            'version': version
        }
    return None

def process_packet(parsed):
    inode, uid, direction = lookup_socket(
        parsed['src_ip'], parsed['src_port'],
        parsed['dst_ip'], parsed['dst_port'],
        parsed['proto'], parsed['version']
    )
    
    length = parsed['len']
    
    if inode is not None:
        proc_info = inode_to_proc.get(inode)
        if proc_info:
            pid = proc_info['pid']
            name = proc_info['name']
            user = proc_info['user']
            container = proc_info['container']
        else:
            pid = None
            name = "Unknown"
            user = get_username(uid)
            container = None
            proc_scan_event.set()
    else:
        pid = None
        name = "Unknown"
        user = "unknown"
        container = None
        socket_scan_event.set()
        
    key = (name, user, container)
    with traffic_lock:
        if key not in second_accumulator:
            second_accumulator[key] = {'sent': 0, 'recv': 0, 'pid': pid}
        if direction == 'out':
            second_accumulator[key]['sent'] += length
        else:
            second_accumulator[key]['recv'] += length
            
        if key not in minute_accumulator:
            minute_accumulator[key] = {'sent': 0, 'recv': 0}
        if direction == 'out':
            minute_accumulator[key]['sent'] += length
        else:
            minute_accumulator[key]['recv'] += length
            
        conn_key = (parsed['src_ip'], parsed['src_port'], parsed['dst_ip'], parsed['dst_port'], parsed['proto'], name)
        if conn_key not in active_connections_accumulator:
            active_connections_accumulator[conn_key] = {'sent': 0, 'recv': 0}
        if direction == 'out':
            active_connections_accumulator[conn_key]['sent'] += length
        else:
            active_connections_accumulator[conn_key]['recv'] += length

# Alert logger
def trigger_alert(process_name, message, severity):
    now = time.time()
    cache_key = (process_name, message)
    if cache_key in alert_cache:
        if now - alert_cache[cache_key] < 300: # rate-limit to once per 5 minutes
            return
    alert_cache[cache_key] = now
    
    try:
        conn = sqlite3.connect(db_manager.db_path)
        cursor = conn.cursor()
        cursor.execute('''
            INSERT INTO alerts (timestamp, process_name, message, severity)
            VALUES (?, ?, ?, ?)
        ''', (int(now), process_name, message, severity))
        conn.commit()
        conn.close()
    except Exception as e:
        logger.error(f"Failed to save alert in database: {e}")
        
    if main_loop:
        asyncio.run_coroutine_threadsafe(
            send_alert_async(int(now), process_name, message, severity),
            main_loop
        )

async def send_alert_async(timestamp, process_name, message, severity):
    payload = {
        'type': 'alert',
        'data': {
            'timestamp': timestamp,
            'process_name': process_name,
            'message': message,
            'severity': severity
        }
    }
    msg_str = json.dumps(payload)
    for ws in list(active_websockets):
        try:
            await ws.send_text(msg_str)
        except Exception:
            active_websockets.discard(ws)

# Broadcast Metrics to WebSockets
def broadcast_realtime_data(timestamp, total_sent, total_recv, top_processes):
    if not active_websockets:
        return
    if main_loop:
        asyncio.run_coroutine_threadsafe(
            send_metrics_async(timestamp, total_sent, total_recv, top_processes),
            main_loop
        )

async def send_metrics_async(timestamp, total_sent, total_recv, top_processes):
    payload = {
        'type': 'metrics',
        'data': {
            'timestamp': timestamp,
            'total_sent_rate': total_sent,
            'total_recv_rate': total_recv,
            'session_total_bytes': session_total_bytes,
            'top_processes': top_processes,
            'connections': [
                {
                    'proto': v['proto'],
                    'process': v['process'],
                    'src': f"{v['src_ip']}:{v['src_port']}",
                    'dst': f"{v['dst_ip']}:{v['dst_port']}",
                    'sent_rate': v['sent_rate'],
                    'recv_rate': v['recv_rate']
                } for v in active_connections_history.values()
            ]
        }
    }
    msg_str = json.dumps(payload)
    for ws in list(active_websockets):
        try:
