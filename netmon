    return {'status': 'success', 'settings': SETTINGS}

@app.get("/api/export")
def export_data(range: str = '24h', format: str = 'csv'):
    if range not in ['24h', '7d', '30d', 'all']:
        range = '24h'
        
    data = db_manager.get_history(range)
    if format == 'json':
        return data
        
    # Standard CSV writer streaming response
    output = io.StringIO()
    writer = csv.writer(output)
    writer.writerow(['timestamp', 'name', 'user', 'container', 'bytes_sent', 'bytes_recv'])
    for row in data:
        writer.writerow([
            row['timestamp'],
            row['name'],
            row['user'],
            row['container'] or '',
            row['bytes_sent'],
            row['bytes_recv']
        ])
    output.seek(0)
    return StreamingResponse(
        io.StringIO(output.getvalue()), 
        media_type="text/csv", 
        headers={"Content-Disposition": f"attachment; filename=netmon_export_{range}.csv"}
    )

@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    active_websockets.add(websocket)
    
    # Send initial history
    try:
        # Format the last 60 points of realtime total speed to let the chart fill up immediately
        initial_points = []
        for pt in list(realtime_history):
            initial_points.append({
                'timestamp': pt['timestamp'],
                'total_sent_rate': pt['total_sent'],
                'total_recv_rate': pt['total_recv']
            })
        await websocket.send_json({
            'type': 'history',
            'data': initial_points
        })
        
        while True:
            # Keep connection open, client is passive listener
            await websocket.receive_text()
    except WebSocketDisconnect:
        active_websockets.discard(websocket)
    except Exception:
        active_websockets.discard(websocket)

