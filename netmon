        except Exception:
            active_websockets.discard(ws)

# Threads Run Loops
def packet_sniff_loop():
    logger.info("Packet sniffer loop thread starting...")
    use_mock = False
    try:
        # AF_PACKET/SOCK_DGRAM cooked socket, binding to ETH_P_ALL
        s = socket.socket(socket.AF_PACKET, socket.SOCK_DGRAM, socket.htons(3))
        s.settimeout(0.5)
    except Exception as e:
        logger.warning(f"Raw socket initialization failed: {e}. Falling back to MOCK Sniffer Mode for testing/non-root environment.")
        use_mock = True

    if use_mock:
        import random
        # Create some mock connections
        mock_conns = [
            ('127.0.0.1', 443, '192.168.1.15', 54321, 'tcp', 'nginx'),
            ('8.8.8.8', 53, '192.168.1.15', 38291, 'udp', 'systemd-resolved'),
            ('142.250.190.46', 443, '192.168.1.15', 49210, 'tcp', 'chrome'),
            ('172.24.0.100', 8008, '192.168.1.15', 39122, 'tcp', 'python3')
        ]
        # Register mock connections in active_sockets & inode_to_proc to allow lookups
        for idx, (rem_ip, rem_port, loc_ip, loc_port, proto, proc) in enumerate(mock_conns):
            key = (loc_ip, loc_port, rem_ip, rem_port, proto)
            inode = 999000 + idx
            active_sockets[key] = (inode, 1000)
            inode_to_proc[inode] = {
                'pid': 9000 + idx,
                'name': proc,
                'user': 'server',
                'container': 'docker-container' if idx == 3 else None
            }
            
        while not stop_event.is_set():
            time.sleep(0.1)
            # Pick a random connection and send/receive random bytes
            conn = random.choice(mock_conns)
            rem_ip, rem_port, loc_ip, loc_port, proto, proc = conn
            length = random.randint(64, 1500)
            direction = random.choice(['in', 'out'])
            
            # Key accumulator info
            key = (proc, 'server', 'docker-container' if proc == 'python3' else None)
            
            with traffic_lock:
                if key not in second_accumulator:
                    second_accumulator[key] = {'sent': 0, 'recv': 0, 'pid': 9000 + mock_conns.index(conn)}
                if direction == 'out':
                    second_accumulator[key]['sent'] += length
                else:
                    second_accumulator[key]['recv'] += length
                    
                if key not in minute_accumulator:
                    minute_accumulator[key] = {'sent': 0, 'recv': 0}
                if direction == 'out':
                    minute_accumulator[key]['sent'] += length
                else:
                    minute_accumulator[key]['recv'] += length
                    
                src_ip = loc_ip if direction == 'out' else rem_ip
                src_port = loc_port if direction == 'out' else rem_port
                dst_ip = rem_ip if direction == 'out' else loc_ip
                dst_port = rem_port if direction == 'out' else loc_port
                
                conn_key = (src_ip, src_port, dst_ip, dst_port, proto, proc)
                if conn_key not in active_connections_accumulator:
                    active_connections_accumulator[conn_key] = {'sent': 0, 'recv': 0}
                if direction == 'out':
                    active_connections_accumulator[conn_key]['sent'] += length
                else:
                    active_connections_accumulator[conn_key]['recv'] += length
        logger.info("Mock packet sniffer loop thread stopped.")
        return

    while not stop_event.is_set():
        try:
            data, addr = s.recvfrom(65535)
            parsed = parse_packet(data)
            if parsed:
                process_packet(parsed)
        except socket.timeout:
            continue
        except Exception as e:
            logger.error(f"Error reading packets: {e}")
    s.close()
    logger.info("Packet sniffer loop thread stopped.")

def socket_scanner_loop():
    logger.info("Socket connections scanner thread starting...")
    while not stop_event.is_set():
        try:
            scan_active_sockets()
        except Exception as e:
            logger.error(f"Error scanning active socket namespaces: {e}")
        # Wait for timeout (1s) or immediate socket scan trigger
        socket_scan_event.wait(timeout=1.0)
        socket_scan_event.clear()
    logger.info("Socket connections scanner thread stopped.")

def proc_scanner_loop():
    logger.info("Proc process file descriptors scanner thread starting...")
    last_scan = 0
    # Run initial scan
    scan_proc_fds()
    
    while not stop_event.is_set():
        proc_scan_event.wait(timeout=0.5)
        if stop_event.is_set():
            break
            
        now = time.time()
        # Rate limit proc directory traversal to at most once per 200ms (5Hz)
        if now - last_scan >= 0.2:
            try:
                scan_proc_fds()
                last_scan = now
            except Exception as e:
                logger.error(f"Error traversing /proc filesystem: {e}")
            proc_scan_event.clear()
    logger.info("Proc process file descriptors scanner thread stopped.")

def aggregator_loop():
    global second_accumulator, minute_accumulator, active_connections_accumulator, session_total_bytes
    logger.info("Traffic aggregator loop thread starting...")
    last_minute_flush = time.time()
    
    while not stop_event.is_set():
        time.sleep(1.0)
        now = time.time()
        now_int = int(now)
        
        with traffic_lock:
            sec_data = second_accumulator
            second_accumulator = {}
            conn_data = active_connections_accumulator
            active_connections_accumulator = {}
            
        total_sent = 0
        total_recv = 0
        proc_list = []
        for (name, user, container), stats in sec_data.items():
            sent = stats['sent']
            recv = stats['recv']
            total_sent += sent
            total_recv += recv
            proc_list.append({
                'name': name,
                'user': user,
                'container': container,
                'pid': stats['pid'],
                'sent': sent,
                'recv': recv
            })
            
            # Speed limits alerting logic
            limit_bytes = SETTINGS['alert_threshold_mb_s'] * 1024 * 1024
            if (sent + recv) > limit_bytes:
                trigger_alert(name, f"Bandwidth limit exceeded: {format_speed(sent + recv)}", "WARNING")
                
            if name == "Unknown" and SETTINGS['check_unknown_process']:
                unknown_limit = SETTINGS['alert_unknown_process_threshold_mb_s'] * 1024 * 1024
                if (sent + recv) > unknown_limit:
                    trigger_alert(name, f"Unknown application generating heavy traffic: {format_speed(sent + recv)}", "INFO")
                    
        session_total_bytes += total_sent + total_recv
        proc_list.sort(key=lambda x: x['sent'] + x['recv'], reverse=True)
        
        realtime_history.append({
            'timestamp': now_int,
            'total_sent': total_sent,
            'total_recv': total_recv,
            'processes': proc_list[:20]
        })
        
        # Connections rates
        for conn_key, stats in conn_data.items():
            src_ip, src_port, dst_ip, dst_port, proto, proc_name = conn_key
            sent = stats['sent']
            recv = stats['recv']
            conn_id = f"{proto}://{src_ip}:{src_port}<->{dst_ip}:{dst_port}"
            active_connections_history[conn_id] = {
                'src_ip': src_ip,
                'src_port': src_port,
                'dst_ip': dst_ip,
                'dst_port': dst_port,
                'proto': proto,
                'process': proc_name,
                'sent_rate': sent,
                'recv_rate': recv,
                'last_seen': now_int
            }
            
        for cid in list(active_connections_history.keys()):
            if now_int - active_connections_history[cid]['last_seen'] > 10:
                active_connections_history.pop(cid, None)
                
        broadcast_realtime_data(now_int, total_sent, total_recv, proc_list[:10])
        
        # Flush aggregates database every 60 seconds
        if now - last_minute_flush >= 60.0:
            last_minute_flush = now
            with traffic_lock:
                min_data = minute_accumulator
                minute_accumulator = {}
                
            if min_data:
                batch = []
                for (name, user, container), stats in min_data.items():
                    batch.append((now_int, name, user, container, stats['sent'], stats['recv']))
                try:
                    db_manager.write_raw_batch(batch)
                except Exception as e:
                    logger.error(f"Error logging batch database metrics: {e}")
    logger.info("Traffic aggregator loop thread stopped.")

def rollup_loop():
    logger.info("Database rollup agent thread starting...")
    last_rollup = time.time()
    while not stop_event.is_set():
        time.sleep(10.0)
        now = time.time()
        if now - last_rollup >= 3600:
            try:
                db_manager.rollup_and_prune()
                last_rollup = now
            except Exception as e:
                logger.error(f"Rollup agent error: {e}")
    logger.info("Database rollup agent thread stopped.")

