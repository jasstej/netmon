    <script>
        // Data formatters
        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // DOM Elements builders (strictly avoiding innerHTML for XSS)
        function el(tag, attrs = {}, children = []) {
            const element = document.createElement(tag);
            for (const [key, val] of Object.entries(attrs)) {
                if (key.startsWith('on') && typeof val === 'function') {
                    element.addEventListener(key.substring(2).toLowerCase(), val);
                } else {
                    element.setAttribute(key, val);
                }
            }
            if (typeof children === 'string') {
                element.textContent = children;
            } else if (Array.isArray(children)) {
                children.forEach(child => {
                    if (typeof child === 'string') {
                        element.appendChild(document.createTextNode(child));
                    } else if (child instanceof HTMLElement) {
                        element.appendChild(child);
                    }
                });
            } else if (children instanceof HTMLElement) {
                element.appendChild(children);
            }
            return element;
        }

        // Custom Canvas Chart Engine
        class RealtimeChart {
            constructor(canvas) {
                this.canvas = canvas;
                this.ctx = canvas.getContext('2d');
                this.history = [];
                this.maxPoints = 60;
                window.addEventListener('resize', () => this.resize());
                this.resize();
            }

            resize() {
                const rect = this.canvas.getBoundingClientRect();
                const dpr = window.devicePixelRatio || 1;
                this.canvas.width = rect.width * dpr;
                this.canvas.height = rect.height * dpr;
                this.ctx.scale(dpr, dpr);
                this.width = rect.width;
                this.height = rect.height;
                this.draw();
            }

            addData(download, upload) {
                this.history.push({ download, upload });
                if (this.history.length > this.maxPoints) {
                    this.history.shift();
                }
                this.draw();
            }

            fillHistory(historyData) {
                this.history = historyData.map(pt => ({
                    download: pt.total_recv_rate,
                    upload: pt.total_sent_rate
                }));
                this.draw();
            }

            draw() {
                const ctx = this.ctx;
                ctx.clearRect(0, 0, this.width, this.height);
                if (this.history.length < 2) return;

                let maxVal = 1024 * 1024; // Min scale 1 MB/s
                this.history.forEach(d => {
                    if (d.download > maxVal) maxVal = d.download;
                    if (d.upload > maxVal) maxVal = d.upload;
                });

                // Draw background grid lines
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';
                ctx.lineWidth = 1;
                ctx.beginPath();
                for (let i = 1; i < 4; i++) {
                    const y = (this.height / 4) * i;
                    ctx.moveTo(0, y);
                    ctx.lineTo(this.width, y);
                }
                ctx.stroke();

                // Axis text labels
                ctx.fillStyle = '#64748b';
                ctx.font = '10px "Outfit", sans-serif';
                for (let i = 0; i < 4; i++) {
                    const val = maxVal * (1 - i / 4);
                    ctx.fillText(formatBytes(val) + '/s', 10, (this.height / 4) * i + 14);
                }

                const getX = (index) => (index / (this.maxPoints - 1)) * this.width;
                const getY = (val) => this.height - (val / maxVal) * (this.height - 24) - 12;

                // Plot lines
                this.drawLinePath(ctx, getX, getY, d => d.download, '#06b6d4', 'rgba(6, 182, 212, 0.04)');
                this.drawLinePath(ctx, getX, getY, d => d.upload, '#f97316', 'rgba(249, 115, 22, 0.04)');
            }

            drawLinePath(ctx, getX, getY, valExtractor, color, fillColor) {
                ctx.beginPath();
                ctx.moveTo(getX(0), getY(valExtractor(this.history[0])));
                for (let i = 1; i < this.history.length; i++) {
                    ctx.lineTo(getX(i), getY(valExtractor(this.history[i])));
                }
                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.stroke();

                ctx.lineTo(getX(this.history.length - 1), this.height);
                ctx.lineTo(getX(0), this.height);
                ctx.closePath();
                ctx.fillStyle = fillColor;
                ctx.fill();
            }
        }

        // Global objects
        let chartInstance;
        let wsConn;
        let sessionTotalTraffic = 0;
        let currentSearchAppQuery = "";
        let currentSearchConnQuery = "";

        // Tab Views Navigation
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', function() {
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                document.querySelectorAll('.tab-view').forEach(v => v.classList.remove('active'));
                
                this.classList.add('active');
                const target = this.getAttribute('data-target');
                document.getElementById(target).classList.add('active');
                
                if (target === 'view-history') {
                    queryHistory();
                } else if (target === 'view-alerts') {
                    queryAlerts();
                } else if (target === 'view-settings') {
                    querySettings();
                }
            });
        });

        // Initialize Realtime Chart
        window.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('speedChart');
            chartInstance = new RealtimeChart(canvas);
            
            // Periodically check FastAPI server status
            updateSystemStatus();
            setInterval(updateSystemStatus, 5000);
            
            // Connect socket
            connectWebSocket();

            // Search event listeners
            document.getElementById('app-search').addEventListener('input', (e) => {
                currentSearchAppQuery = e.target.value.toLowerCase();
            });
            document.getElementById('conn-search').addEventListener('input', (e) => {
                currentSearchConnQuery = e.target.value.toLowerCase();
            });

            // History elements listeners
            document.getElementById('history-range-select').addEventListener('change', queryHistory);
            document.getElementById('btn-export-json').addEventListener('click', () => triggerExport('json'));
            document.getElementById('btn-export-csv').addEventListener('click', () => triggerExport('csv'));
            document.getElementById('btn-print-report').addEventListener('click', () => window.print());

            // Settings buttons
            document.getElementById('btn-save-settings').addEventListener('click', saveSettings);
            document.getElementById('setting-check-unknown').addEventListener('change', function() {
                document.getElementById('group-unknown-threshold').style.display = this.checked ? 'flex' : 'none';
            });
        });

        function connectWebSocket() {
            const proto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const host = window.location.host;
            wsConn = new WebSocket(`${proto}//${host}/ws`);
            
            const dot = document.getElementById('ws-status-dot');
            const text = document.getElementById('ws-status-text');

            wsConn.onopen = () => {
                dot.style.backgroundColor = 'var(--color-success)';
                dot.style.boxShadow = '0 0 8px var(--color-success)';
                text.textContent = 'Connected';
            };

            wsConn.onclose = () => {
                dot.style.backgroundColor = 'var(--color-warning)';
                dot.style.boxShadow = '0 0 8px var(--color-warning)';
                text.textContent = 'Disconnected';
                setTimeout(connectWebSocket, 3000); // retry
            };

            wsConn.onmessage = (event) => {
                const message = JSON.parse(event.data);
                if (message.type === 'history') {
                    chartInstance.fillHistory(message.data);
                } else if (message.type === 'metrics') {
                    renderRealtimeMetrics(message.data);
                } else if (message.type === 'alert') {
                    displayRealtimeAlertNotification(message.data);
                }
            };
        }

        // Live calculations & renderer
        function renderRealtimeMetrics(data) {
            // Stat values
            document.getElementById('stat-download-rate').textContent = formatBytes(data.total_recv_rate) + '/s';
            document.getElementById('stat-upload-rate').textContent = formatBytes(data.total_sent_rate) + '/s';
            
            sessionTotalTraffic = data.session_total_bytes;
            document.getElementById('stat-total-session').textContent = formatBytes(sessionTotalTraffic);

            // Add point to chart
            chartInstance.addData(data.total_recv_rate, data.total_sent_rate);

            // 1. Render Distribution bar-charts
            const distContainer = document.getElementById('dist-bars-container');
            distContainer.replaceChildren();
            
            const activeTop = data.top_processes.slice(0, 5);
            if (activeTop.length === 0) {
                distContainer.appendChild(el('div', { class: 'empty-state' }, 'No active traffic detected.'));
            } else {
                const maxRate = Math.max(...activeTop.map(p => p.sent + p.recv));
                activeTop.forEach(p => {
                    const total = p.sent + p.recv;
                    const pct = maxRate > 0 ? (total / maxRate) * 100 : 0;
                    
                    const labelSpan = el('span', { class: 'bar-label' }, p.name);
                    const valSpan = el('span', { class: 'bar-val' }, formatBytes(total) + '/s');
                    const infoDiv = el('div', { class: 'bar-info' }, [labelSpan, valSpan]);
                    
                    const fillDiv = el('div', { class: 'bar-fill bar-fill-download', style: `width: ${pct}%` });
                    const trackDiv = el('div', { class: 'bar-track' }, [fillDiv]);
                    
                    const container = el('div', { class: 'bar-container' }, [infoDiv, trackDiv]);
                    distContainer.appendChild(container);
                });
            }

            // 2. Render Apps Table
            const appsBody = document.getElementById('apps-table-body');
            appsBody.replaceChildren();
            
            const filteredApps = data.top_processes.filter(p => {
                if (currentSearchAppQuery === "") return true;
                return p.name.toLowerCase().includes(currentSearchAppQuery) || 
                       p.user.toLowerCase().includes(currentSearchAppQuery);
            });

            if (filteredApps.length === 0) {
                appsBody.appendChild(el('tr', {}, [
                    el('td', { colspan: '6', class: 'empty-state' }, 'No applications matching filter...')
                ]));
            } else {
                filteredApps.forEach(p => {
                    const row = el('tr', {}, [
                        el('td', { class: 'font-mono', style: 'font-weight:600;', title: p.name }, p.name),
                        el('td', {}, p.pid !== null ? String(p.pid) : '-'),
                        el('td', {}, p.user),
                        el('td', {}, p.container ? el('span', { class: 'badge badge-container', title: p.container }, p.container) : '-'),
                        el('td', { class: 'font-mono', style: 'color: var(--color-download)' }, formatBytes(p.recv) + '/s'),
                        el('td', { class: 'font-mono', style: 'color: var(--color-upload)' }, formatBytes(p.sent) + '/s')
                    ]);
                    appsBody.appendChild(row);
                });
            }

            // 3. Render Sockets/Connections Table
            const connsBody = document.getElementById('conns-table-body');
            connsBody.replaceChildren();
            
            const filteredConns = data.connections.filter(c => {
                if (currentSearchConnQuery === "") return true;
                return c.process.toLowerCase().includes(currentSearchConnQuery) ||
                       c.src.includes(currentSearchConnQuery) ||
                       c.dst.includes(currentSearchConnQuery);
            });

            if (filteredConns.length === 0) {
                connsBody.appendChild(el('tr', {}, [
                    el('td', { colspan: '6', class: 'empty-state' }, 'No active connections matching filter...')
                ]));
            } else {
                filteredConns.forEach(c => {
                    const row = el('tr', {}, [
                        el('td', {}, [el('span', { class: c.proto === 'tcp' ? 'badge badge-download' : 'badge badge-upload' }, c.proto)]),
                        el('td', { class: 'font-mono', title: c.process }, c.process),
                        el('td', { class: 'font-mono', title: c.src }, c.src),
                        el('td', { class: 'font-mono', title: c.dst }, c.dst),
                        el('td', { class: 'font-mono', style: 'color: var(--color-download)' }, formatBytes(c.recv_rate) + '/s'),
                        el('td', { class: 'font-mono', style: 'color: var(--color-upload)' }, formatBytes(c.sent_rate) + '/s')
                    ]);
                    connsBody.appendChild(row);
                });
            }
        }

        function displayRealtimeAlertNotification(alert) {
            // Auto append or show banner
            const alertsContainer = document.getElementById('alerts-container');
            const empty = alertsContainer.querySelector('.empty-state');
            if (empty) {
                alertsContainer.replaceChildren();
            }
            
            const timeStr = new Date(alert.timestamp * 1000).toLocaleTimeString();
            const textDiv = el('div', {}, [
                el('div', { class: 'alert-item-title' }, `Exceeded alert on [${alert.process_name}]`),
                el('div', { style: 'font-size: 13px; margin-bottom: 5px;' }, alert.message),
                el('span', { class: 'alert-item-time' }, timeStr)
            ]);
            const badge = el('span', { class: 'badge badge-upload' }, alert.severity);
            const alertItem = el('div', { class: `alert-item severity-${alert.severity.toLowerCase()}` }, [textDiv, badge]);
            
            alertsContainer.insertBefore(alertItem, alertsContainer.firstChild);
        }

        // Status queries
        async function updateSystemStatus() {
            try {
                const res = await fetch('/api/status');
                const status = await res.json();
                
                document.getElementById('sys-uptime').textContent = formatUptime(status.uptime);
                document.getElementById('sys-dbsize').textContent = formatBytes(status.database_size_bytes);
                document.getElementById('sys-sockets').textContent = status.active_sockets_count;
                if (status.session_total_bytes !== undefined) {
                    sessionTotalTraffic = status.session_total_bytes;
                    document.getElementById('stat-total-session').textContent = formatBytes(sessionTotalTraffic);
                }
            } catch (err) {
                console.error("Failed to query status", err);
            }
        }

        function formatUptime(seconds) {
            const h = Math.floor(seconds / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = seconds % 60;
            return `${h}h ${m}m ${s}s`;
        }

        // Database queries (History Tab)
        async function queryHistory() {
            const range = document.getElementById('history-range-select').value;
            const title = document.getElementById('history-consumers-title');
            
            let labelRange = "Last 24 Hours";
            if (range === '7d') labelRange = "Last 7 Days";
            else if (range === '30d') labelRange = "Last 30 Days";
            else if (range === 'all') labelRange = "All Time";
            title.textContent = `Top Bandwidth Consumers (${labelRange})`;

            const body = document.getElementById('history-table-body');
            body.replaceChildren();
            body.appendChild(el('tr', {}, [el('td', { colspan: '6', class: 'empty-state' }, 'Loading data from sqlite...')]));

            try {
                const res = await fetch(`/api/top?range=${range}`);
                const data = await res.json();
                
                body.replaceChildren();
                if (data.length === 0) {
                    body.appendChild(el('tr', {}, [el('td', { colspan: '6', class: 'empty-state' }, 'No historical records found for this range.')]));
                } else {
                    data.forEach(row => {
                        const tr = el('tr', {}, [
                            el('td', { class: 'font-mono', style: 'font-weight:600' }, row.name),
                            el('td', {}, row.user),
                            el('td', {}, row.container ? el('span', { class: 'badge badge-container' }, row.container) : '-'),
                            el('td', { class: 'font-mono', style: 'color: var(--color-download)' }, formatBytes(row.recv)),
                            el('td', { class: 'font-mono', style: 'color: var(--color-upload)' }, formatBytes(row.sent)),
                            el('td', { class: 'font-mono', style: 'font-weight:700' }, formatBytes(row.total))
                        ]);
                        body.appendChild(tr);
                    });
                }
            } catch (err) {
                body.replaceChildren();
                body.appendChild(el('tr', {}, [el('td', { colspan: '6', class: 'empty-state', style: 'color: var(--color-warning)' }, 'Failed to load data.')]));
            }
        }

        function triggerExport(format) {
            const range = document.getElementById('history-range-select').value;
            window.location.href = `/api/export?range=${range}&format=${format}`;
        }

        // Alerts query
        async function queryAlerts() {
            const container = document.getElementById('alerts-container');
            container.replaceChildren();
            container.appendChild(el('div', { class: 'empty-state' }, 'Loading alerts...'));

            try {
                const res = await fetch('/api/alerts');
                const data = await res.json();
                container.replaceChildren();
                
                if (data.length === 0) {
                    container.appendChild(el('div', { class: 'empty-state' }, 'No anomalies detected in the database.'));
                } else {
                    data.forEach(alert => {
                        const timeStr = new Date(alert.timestamp * 1000).toLocaleString();
                        const textDiv = el('div', {}, [
                            el('div', { class: 'alert-item-title' }, `Anomalous activity on [${alert.process_name}]`),
                            el('div', { style: 'font-size: 13px; margin-bottom: 5px;' }, alert.message),
                            el('span', { class: 'alert-item-time' }, timeStr)
                        ]);
                        const badge = el('span', { class: `badge ${alert.severity === 'WARNING' ? 'badge-upload' : 'badge-download'}` }, alert.severity);
                        const alertItem = el('div', { class: `alert-item severity-${alert.severity.toLowerCase()}` }, [textDiv, badge]);
                        container.appendChild(alertItem);
                    });
                }
            } catch (err) {
                container.replaceChildren();
                container.appendChild(el('div', { class: 'empty-state', style: 'color: var(--color-warning)' }, 'Failed to fetch alert logs.'));
            }
        }

        // Settings query & save
        async function querySettings() {
            try {
                const res = await fetch('/api/settings');
                const settings = await res.json();
                
                document.getElementById('setting-threshold').value = settings.alert_threshold_mb_s;
                
                const checkUnknown = document.getElementById('setting-check-unknown');
                checkUnknown.checked = settings.check_unknown_process;
                
                document.getElementById('group-unknown-threshold').style.display = settings.check_unknown_process ? 'flex' : 'none';
                document.getElementById('setting-unknown-threshold').value = settings.alert_unknown_process_threshold_mb_s;
            } catch (err) {
                console.error("Failed to load settings", err);
            }
        }

        async function saveSettings() {
            const threshold = parseFloat(document.getElementById('setting-threshold').value);
            const checkUnknown = document.getElementById('setting-check-unknown').checked;
            const unknownThreshold = parseFloat(document.getElementById('setting-unknown-threshold').value);

            const payload = {
                alert_threshold_mb_s: threshold,
                check_unknown_process: checkUnknown,
                alert_unknown_process_threshold_mb_s: unknownThreshold
            };

            try {
                const res = await fetch('/api/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (res.ok) {
                    alert("Settings saved successfully.");
                } else {
                    alert("Failed to save settings.");
                }
            } catch (err) {
                alert("Error connecting to backend API.");
            }
        }
    </script>
</body>
</html>
"""

# Global program boot timer
start_time = int(time.time())

if __name__ == "__main__":
    # Check root privileges and auto-escalate with sudo if not root
    if os.getuid() != 0:
        if "--mock" in sys.argv or os.environ.get("NETMON_MOCK") == "1":
            logger.warning("NetMon is not running as root, but mock mode is requested. Starting in mock mode.")
        else:
            logger.info("NetMon must be executed with root privileges. Re-running with sudo...")
            script_path = os.path.abspath(sys.argv[0])
            args = [arg for arg in sys.argv[1:] if arg != "--mock"]
            try:
                os.execvp("sudo", ["sudo", sys.executable, script_path, *args])
            except Exception as e:
                logger.critical(f"Failed to auto-escalate privileges using sudo: {e}. Please run manually: sudo {sys.argv[0]}")
                sys.exit(1)
                
    logger.info("Initializing Application Network Monitor (NetMon)...")
    
    # Fire up background threads
    t_sniff = threading.Thread(target=packet_sniff_loop, name="Sniffer", daemon=True)
    t_socks = threading.Thread(target=socket_scanner_loop, name="SockScanner", daemon=True)
    t_proc = threading.Thread(target=proc_scanner_loop, name="ProcScanner", daemon=True)
    t_agg = threading.Thread(target=aggregator_loop, name="Aggregator", daemon=True)
    t_roll = threading.Thread(target=rollup_loop, name="RollupAgent", daemon=True)
    
    t_sniff.start()
    t_socks.start()
    t_proc.start()
    t_agg.start()
    t_roll.start()
    
    try:
        # Start FastAPI Uvicorn Server (Listen on all interfaces to allow external access)
        import uvicorn
        logger.info("Starting web dashboard engine on http://0.0.0.0:3005")
        uvicorn.run(app, host="0.0.0.0", port=3005, log_level="warning")
    except KeyboardInterrupt:
        logger.info("Shutdown initiated via keyboard interrupt.")
    finally:
        # Terminate background loops
        stop_event.set()
        proc_scan_event.set()
        logger.info("Stopping all background services. Please wait...")
        # Join loops with timeout
        t_sniff.join(timeout=1.0)
        t_socks.join(timeout=1.0)
        t_proc.join(timeout=1.0)
        t_agg.join(timeout=1.0)
        t_roll.join(timeout=1.0)
        logger.info("NetMon exited cleanly.")
