#!/usr/bin/env python3
"""
Application-Level Network Usage Monitor (NetMon)
A lightweight, single-file network traffic daemon, logger, and web dashboard.
Runs on Linux, tracks traffic per process/user/container, and stores hourly/daily/monthly summaries.
"""

import os
import sys
import subprocess

# Self-installing dependencies list
REQUIRED_PACKAGES = ["fastapi", "uvicorn", "websockets"]

def auto_install_packages():
    missing = []
    for pkg in REQUIRED_PACKAGES:
        try:
            __import__(pkg)
        except ImportError:
            missing.append(pkg)
    if missing:
        print(f"Missing required Python libraries: {missing}. Installing automatically...", flush=True)
        try:
            # Execute pip install inside current Python interpreter environment
            # We attempt to use --break-system-packages to override Debian/Ubuntu PEP 668 lockouts
            cmd = [sys.executable, "-m", "pip", "install"]
            try:
                subprocess.check_call(cmd + ["--break-system-packages", *missing])
            except subprocess.CalledProcessError:
                # Fallback to standard installation if flag is unsupported
                subprocess.check_call(cmd + missing)
            print("Dependencies installed successfully! Resuming startup...", flush=True)
        except Exception as e:
            print(f"Error: Automatic installation failed: {e}. Please install manually using: pip install " + " ".join(missing), file=sys.stderr, flush=True)
            sys.exit(1)

auto_install_packages()

